# RPC Endpoint Solana
# Gunakan devnet untuk development dan testing
# Untuk production, gunakan RPC provider seperti Helius atau QuickNode
# Prefix NEXT_PUBLIC_ wajib agar variabel bisa diakses di browser
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# Counter Program ID
# Ganti dengan Program ID setelah deploy program Anchor ke devnet:
#   anchor build && anchor deploy --provider.cluster devnet
# Tanpa env var ini, app akan menggunakan placeholder dan program calls akan gagal.
NEXT_PUBLIC_COUNTER_PROGRAM_ID=
